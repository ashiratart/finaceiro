{% extends 'base.html.twig' %}

{% block title %}Dashboard Financeiro{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="/css/dashboard.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
{% endblock %}

{% block body %}

<div class="container-fluid mt-4">

    <h1 class="mb-4">
        Dashboard Financeiro
        <span class="text-muted">| {{ mesAtual }}/{{ anoAtual }}</span>
    </h1>

    <div class="dashboard-layout">

        <!-- FORMULÁRIO -->
        <div class="dashboard-form">
            <div class="card">
                <h4 class="mb-3">Nova Despesa</h4>

                <form method="post" action="{{ path('financas_dashboard') }}">
                    <div class="mb-3">
                        <label class="form-label">Motivo</label>
                        <input type="text" class="form-control" name="motivo" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Valor</label>
                        <input type="number" step="0.01" class="form-control" name="valor" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Data Consumo</label>
                        <input type="date" class="form-control" name="data_consumo" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Data Pagamento</label>
                        <input type="date" class="form-control" name="data_pagamento">
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" name="fixo">
                        <label class="form-check-label">Despesa fixa</label>
                    </div>

                    <button type="submit" class="btn-primary-custom">
                        Salvar
                    </button>
                </form>
            </div>
        </div>

        <!-- DASHBOARD -->
        <div class="dashboard-content">

            <!-- KPIs -->
            <div class="graficos-grid mb-4">
                <div>
                    <div class="kpi-card">
                        <div class="kpi-title">Despesas Fixas</div>
                        <div class="kpi-value">R$ {{ totalPago|number_format(2, ',', '.') }}</div>
                    </div>
                </div>

                <div>
                    <div class="kpi-card">
                        <div class="kpi-title">Consumo</div>
                        <div class="kpi-value">R$ {{ totalPago|number_format(2, ',', '.') }}</div>
                    </div>
                </div>

                <div>
                    <div class="kpi-card">
                        <div class="kpi-title">Pago</div>
                        <div class="kpi-value text-success">
                            R$ {{ totalPago|number_format(2, ',', '.') }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- GRÁFICOS -->
            <div class="graficos-grid">
                <div class="card grafico-card">
                    <h6>Fixas</h6>
                    <canvas id="graficoFixas"></canvas>
                </div>

                <div class="card grafico-card">
                    <h6>Consumo</h6>
                    <canvas id="graficoConsumo"></canvas>
                </div>

                <div class="card grafico-card">
                    <h6>Pagas</h6>
                    <canvas id="graficoPagas"></canvas>
                </div>
            </div>

            <!-- TABELAS -->
            <div class="graficos-grid mt-4">

                <div class="card tabela-card">
                    <h6>Fixas</h6>
                    <div class="table-container">
                        <table class="table">
                            {% for d in despesasFixas %}
                            <tr>
                                <td>{{ d.ds_motivo }}</td>
                                <td class="text-end">R$ {{ d.vl_valor|number_format(2, ',', '.') }}</td>
                            </tr>
                            {% endfor %}
                        </table>
                    </div>
                </div>

                <div class="card tabela-card">
                    <h6>Consumo</h6>
                    <div class="table-container">
                        <table class="table">
                            {% for d in despesasConsumo %}
                            <tr>
                                <td>{{ d.ds_motivo }}</td>
                                <td>{{ d.dt_consumo|date('d/m') }}</td>
                                <td class="text-end">R$ {{ d.vl_valor|number_format(2, ',', '.') }}</td>
                            </tr>
                            {% endfor %}
                        </table>
                    </div>
                </div>

                <div class="card tabela-card">
                    <h6>Pagas</h6>
                    <div class="table-container">
                        <table class="table">
                            {% for d in despesasPagas %}
                            <tr>
                                <td>{{ d.ds_motivo }}</td>
                                <td>{{ d.dt_pag|date('d/m') }}</td>
                                <td class="text-end">R$ {{ d.vl_valor|number_format(2, ',', '.') }}</td>
                            </tr>
                            {% endfor %}
                        </table>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {

    /* Plugin texto no centro */
    const centerTextPlugin = {
        id: 'centerText',
        beforeDraw(chart) {
            const { width, height } = chart;
            const ctx = chart.ctx;

            ctx.restore();

            const total = chart.config.data.datasets[0].data
                .reduce((a, b) => a + b, 0);

            const text = "R$ " + total.toLocaleString('pt-BR', {
                minimumFractionDigits: 2
            });

            ctx.font = "bold 16px sans-serif";
            ctx.fillStyle = "#cfcfcf";
            ctx.textBaseline = "middle";

            const textX = Math.round((width - ctx.measureText(text).width) / 2);
            const textY = height / 2;

            ctx.fillText(text, textX, textY);

            ctx.save();
        }
    };

    Chart.register(centerTextPlugin);

    function generateColors(count) {
        const palette = [
            '#4F46E5','#22C55E','#F59E0B','#EF4444',
            '#3B82F6','#10B981','#F97316','#8B5CF6'
        ];
        return Array.from({length: count}, (_, i) => palette[i % palette.length]);
    }

    const chartOptions = {
        responsive: true,
        cutout: '70%',
        plugins: {
            legend: { display: false }
        }
    };

    function createChart(id, labels, data) {
        if (!labels.length) return;

        new Chart(document.getElementById(id), {
            type: 'doughnut',
            data: {
                labels,
                datasets: [{
                    data,
                    backgroundColor: generateColors(labels.length)
                }]
            },
            options: chartOptions
        });
    }

    createChart("graficoFixas",
        [{% for d in despesasFixas %}'{{ d.ds_motivo|e('js') }}',{% endfor %}],
        [{% for d in despesasFixas %}{{ d.vl_valor }},{% endfor %}]
    );

    createChart("graficoConsumo",
        [{% for d in despesasConsumo %}'{{ d.ds_motivo|e('js') }}',{% endfor %}],
        [{% for d in despesasConsumo %}{{ d.vl_valor }},{% endfor %}]
    );

    createChart("graficoPagas",
        [{% for d in despesasPagas %}'{{ d.ds_motivo|e('js') }}',{% endfor %}],
        [{% for d in despesasPagas %}{{ d.vl_valor }},{% endfor %}]
    );

});
</script>

{% endblock %}